# Pfadauflösung für React Native (Hoisting Support)
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.0'

require_relative '../node_modules/@react-native-community/cli-platform-ios/native_modules'

target 'cuteNTR' do
  config = use_native_modules!

  # FIX: Wir nutzen 'min' statt 'https', um den 404-Fehler zu umgehen.
  # 'min' ist für das 3DS-Streaming absolut ausreichend.
  pod 'ffmpeg-kit-ios-min', '6.0'

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :hermes_enabled => true
  )

  target 'cuteNTRTests' do
    inherit! :complete
  end

  post_install do |installer|
    # Standard React Native Einstellungen
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # FIX: Erzwinge iOS 15.0 für alle Pods, um Linker-Fehler zu vermeiden
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      end
    end
  end
end
